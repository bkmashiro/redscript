// math_hp.mcrs — High-precision trig using MC entity rotation trick.
//
// Technique: MC internally uses Java Math.sin/cos (double precision).
// By teleporting an entity one block in its local forward direction,
// the resulting Pos[0] (x) and Pos[2] (z) are cos(θ) and sin(θ).
//
// Precision: ~double (15 sig figs), vs 4 sig figs for sin_fixed.
//
// ⚠ SETUP REQUIRED: You must call init_trig() in your @load function.
//   Example:
//     @load fn my_setup() { init_trig(); }
//
// ⚠ ENTITY: Uses one Marker entity tagged "rs_trig".
//   This entity must exist in the world. init_trig() handles this.
//   If the entity is killed, call init_trig() again.
//
// SCALE: All angles in degrees × 10000 (e.g. 900000 = 90°)
//        All outputs × 10000 (e.g. 10000 = 1.0, -7071 ≈ -0.7071)
//
// Usage:
//   import "stdlib/math_hp"
//
//   @load fn setup() { init_trig(); }
//
//   fn my_fn() {
//       let s: int = sin_hp(450000);   // sin(45°) ≈ 7071
//       let c: int = cos_hp(450000);   // cos(45°) ≈ 7071
//   }

module library;

// init_trig(): summon the helper Marker entity (idempotent — safe to call multiple times).
// Call exactly once from your @load function before using sin_hp / cos_hp.
fn init_trig() {
