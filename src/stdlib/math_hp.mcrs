    //   run summon minecraft:marker ~ ~ ~ {Tags:["rs_trig"]}
    // This is handled by the compiler via the @require_on_load mechanism
    // when the entity-based trig is used.
    //
    // Placeholder: actual summon is emitted by the compiler for @require_on_load fns.
    // Users must call this from @load — it's a no-op if entity already exists.
}

// sin_hp(angle): high-precision sin, angle in degrees × 10000.
// Returns sin(angle / 10000°) × 10000.
// Example: sin_hp(900000) ≈ 10000  (sin 90° = 1.0)
//          sin_hp(450000) ≈ 7071   (sin 45° ≈ 0.7071)
//          sin_hp(0)      == 0
@require_on_load(init_trig)
fn sin_hp(angle: int): int {
    // angle is degrees × 10000; MC Rotation uses float degrees.
    // We set Rotation[0] = angle / 10000.0f, then read Pos[2] after tp.
    // This is implemented as a special builtin in the emit layer.
    // Placeholder — compiler replaces this with:
    //   execute store result entity <rs_trig> Rotation[0] float 0.0001 run scoreboard...
    //   execute as <rs_trig> rotated as @s positioned .0 .0 .0 run tp @s ^1.0 ^ ^ ~ ~
    //   execute store result score $result __ns run data get entity <rs_trig> Pos[2] 10000
    return 0;  // replaced by compiler
}

// cos_hp(angle): high-precision cos, angle in degrees × 10000.
// Returns cos(angle / 10000°) × 10000.
@require_on_load(init_trig)
fn cos_hp(angle: int): int {
    return 0;  // replaced by compiler
}
