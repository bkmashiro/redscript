/// All pressure plates
const TAG_PRESSURE_PLATES: string = "#minecraft:pressure_plates";

/// All stairs
const TAG_STAIRS: string = "#minecraft:stairs";

/// All slabs
const TAG_SLABS: string = "#minecraft:slabs";

/// All fences
const TAG_FENCES: string = "#minecraft:fences";

/// All walls
const TAG_WALLS: string = "#minecraft:walls";

/// All signs
const TAG_SIGNS: string = "#minecraft:signs";

/// All beds
const TAG_BEDS: string = "#minecraft:beds";

/// All flowers
const TAG_FLOWERS: string = "#minecraft:flowers";

/// All saplings
const TAG_SAPLINGS: string = "#minecraft:saplings";

/// All leaves
const TAG_LEAVES: string = "#minecraft:leaves";

/// All crops
const TAG_CROPS: string = "#minecraft:crops";

/// All ores
const TAG_COAL_ORES: string = "#minecraft:coal_ores";
const TAG_IRON_ORES: string = "#minecraft:iron_ores";
const TAG_GOLD_ORES: string = "#minecraft:gold_ores";
