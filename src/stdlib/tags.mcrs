// ===== Item Tags =====

/// All swords
const TAG_SWORDS: string = "#minecraft:swords";

/// All axes
const TAG_AXES: string = "#minecraft:axes";

/// All pickaxes  
const TAG_PICKAXES: string = "#minecraft:pickaxes";

/// All shovels
const TAG_SHOVELS: string = "#minecraft:shovels";

/// All hoes
const TAG_HOES: string = "#minecraft:hoes";

/// All armor trims
