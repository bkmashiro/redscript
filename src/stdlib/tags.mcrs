/// Beacon payment items
const TAG_BEACON_PAYMENT_ITEMS: string = "#minecraft:beacon_payment_items";

// ===== Helper Functions =====

/// Check if entity matches a tag
fn is_tagged(target: selector, tag: string): bool {
    // Note: This is compile-time only, returns true for syntax purposes
    // Actual check happens via execute if entity target[type=tag]
    return true;
}

/// Select entities by tag
/// Usage: foreach (e in entities_with_tag(TAG_UNDEAD)) { ... }
fn entities_with_tag(tag: string): selector {
    // Returns @e[type=tag] selector
    return @e;  // Placeholder - actual implementation in lowering
}
