// ============================================
// Minecraft Entity & Block Tags
// ============================================
// Built-in tag constants for type checking and selection
// Usage: @e[type=#TAG_UNDEAD] or if (e is #TAG_RAIDERS)
// ============================================

// ===== Entity Type Tags =====

/// Undead mobs (zombies, skeletons, phantoms, etc.)
/// Affected by Smite enchantment, healed by harming potions
const TAG_UNDEAD: string = "#minecraft:undead";

/// Arthropod mobs (spiders, silverfish, endermites, bees)
/// Affected by Bane of Arthropods enchantment
const TAG_ARTHROPODS: string = "#minecraft:arthropods";

/// Illager raiders (pillagers, vindicators, evokers, etc.)
const TAG_RAIDERS: string = "#minecraft:raiders";

/// All skeleton variants
const TAG_SKELETONS: string = "#minecraft:skeletons";

/// All zombie variants  
const TAG_ZOMBIES: string = "#minecraft:zombies";

/// Mobs that can be tamed
const TAG_CAN_BREATHE_UNDER_WATER: string = "#minecraft:can_breathe_under_water";

/// Entities immune to fire
const TAG_FREEZE_IMMUNE_ENTITY_TYPES: string = "#minecraft:freeze_immune_entity_types";

/// Powder snow walkable entities
const TAG_POWDER_SNOW_WALKABLE_MOBS: string = "#minecraft:powder_snow_walkable_mobs";

/// Impact projectiles (arrows, tridents, etc.)
const TAG_IMPACT_PROJECTILES: string = "#minecraft:impact_projectiles";

/// Aquatic mobs
const TAG_AQUATIC: string = "#minecraft:aquatic";

/// Axolotl huntable mobs
const TAG_AXOLOTL_HUNT_TARGETS: string = "#minecraft:axolotl_hunt_targets";

/// Warden anger targets
const TAG_WARDEN_CAN_LISTEN: string = "#minecraft:warden_can_listen";

