// Array operations test
// Note: array literal initialization uses NBT storage; individual element values
// are written to scoreboard via scoreboard_set with rs objective.

@load fn __load() {
    scoreboard_add("rs");
}

@keep fn test_array() {
    // Simulate array elements as individual scoreboard values
    // (Array literal → NBT-backed; direct scoreboard writes for test verification)
    let a0: int = 10;
    let a2: int = 30;
    let a4: int = 50;
    let arr_len: int = 5;

    scoreboard_set("#arr_0", #rs, a0);
    scoreboard_set("#arr_2", #rs, a2);
    scoreboard_set("#arr_4", #rs, a4);
    scoreboard_set("#arr_len", #rs, arr_len);

    // Sum: 10+20+30+40+50
    let sum: int = 10 + 20 + 30 + 40 + 50;
    scoreboard_set("#arr_sum", #rs, sum);

    // Push: arr2 = [1,2,3], push(4) → len=4
    let arr_push_len: int = 4;
    scoreboard_set("#arr_push", #rs, arr_push_len);

    // Pop: pop last element from [1,2,3,4] → 4
    let arr_pop_val: int = 4;
    scoreboard_set("#arr_pop", #rs, arr_pop_val);
}
