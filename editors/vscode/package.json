{
  "name": "redscript-vscode",
  "displayName": "RedScript for Minecraft",
  "description": "Syntax highlighting, error diagnostics, and language support for RedScript — a compiler targeting Minecraft Java Edition",
  "version": "1.3.90",
  "publisher": "bkmashiro",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bkmashiro/redscript"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "minecraft",
    "mcfunction",
    "redscript",
    "datapack",
    "compiler"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:redscript"
  ],
  "contributes": {
    "languages": [
      {
        "id": "redscript",
        "aliases": [
          "RedScript",
          "redscript"
        ],
        "extensions": [
          ".mcrs"
        ],
        "configuration": "./redscript-language-configuration.json"
      },
      {
        "id": "mcfunction",
        "aliases": [
          "mcfunction",
          "Minecraft Function"
        ],
        "extensions": [
          ".mcfunction"
        ],
        "configuration": "./mcfunction-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "redscript",
        "scopeName": "source.redscript",
        "path": "./syntaxes/redscript.tmLanguage.json",
        "embeddedLanguages": {
          "source.mcfunction": "mcfunction"
        }
      },
      {
        "language": "mcfunction",
        "scopeName": "source.mcfunction",
        "path": "./syntaxes/mcfunction.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "redscript",
        "path": "./snippets/redscript.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "variable.other.mc-name.redscript",
            "settings": {
              "foreground": "#F38BA8",
              "fontStyle": ""
            }
          },
          {
            "scope": "keyword.other.selector.redscript",
            "settings": {
              "foreground": "#89B4FA",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "support.type.property-name.redscript",
            "settings": {
              "foreground": "#F9E2AF"
            }
          },
          {
            "scope": "entity.name.namespace.redscript",
            "settings": {
              "foreground": "#6C7086"
            }
          },
          {
            "scope": "entity.name.type.entity.redscript",
            "settings": {
              "foreground": "#CBA6F7"
            }
          },
          {
            "scope": "keyword.operator.range.selector.redscript",
            "settings": {
              "foreground": "#89DCEB"
            }
          }
        ]
      }
    },
    "iconThemes": [
      {
        "id": "redscript-icons",
        "label": "RedScript Icons",
        "path": "./icons/redscript-icons.json"
      }
    ]
  },
  "scripts": {
    "compile": "node build.mjs",
    "watch": "node build.mjs --watch",
    "build": "npm run compile",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "publish": "npm run build && npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "redscript": "file:../../",
    "vscode-languageclient": "^9.0.1"
  }
}
