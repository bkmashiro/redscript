// cube.mcrs — RedScript software rasterizer demo
// A Python offline rasterizer pre-computes 60 frames of a rotating 3D cube.
// Each _frame_XX() function redraws the 21×17 block screen using setblock().
// Coordinates are ^ (local/caret) so the screen always appears 6 blocks
// ahead of the player's current facing direction.
//
// 3D pipeline: Y-rotation × X-tilt → ortho-project → Z-buffer → scanline fill
// 6 face colors: red·blue·cyan·lime·yellow·orange concrete
//
// Compile:
//   node dist/cli.js compile examples/cube-demo/cube.mcrs \
//       -o <datapack-dir> --namespace cubedemo
// In-game:
//   Stand ~15 blocks back, face the wall → /function cubedemo:start
//   /function cubedemo:stop

let frame:   int  = 0;
let running: bool = false;

@load fn _init() {
    frame = 0;
}

@tick fn _tick() {
    if (!running) { return; }
    frame = (frame + 1) % 60;
    // Render frame relative to each player's facing direction
    foreach (p in @a) at @s {
        if (frame == 0) { _frame_00(); }
        if (frame == 1) { _frame_01(); }
        if (frame == 2) { _frame_02(); }
        if (frame == 3) { _frame_03(); }
        if (frame == 4) { _frame_04(); }
        if (frame == 5) { _frame_05(); }
        if (frame == 6) { _frame_06(); }
        if (frame == 7) { _frame_07(); }
        if (frame == 8) { _frame_08(); }
        if (frame == 9) { _frame_09(); }
        if (frame == 10) { _frame_10(); }
        if (frame == 11) { _frame_11(); }
        if (frame == 12) { _frame_12(); }
        if (frame == 13) { _frame_13(); }
        if (frame == 14) { _frame_14(); }
        if (frame == 15) { _frame_15(); }
        if (frame == 16) { _frame_16(); }
        if (frame == 17) { _frame_17(); }
        if (frame == 18) { _frame_18(); }
        if (frame == 19) { _frame_19(); }
        if (frame == 20) { _frame_20(); }
        if (frame == 21) { _frame_21(); }
        if (frame == 22) { _frame_22(); }
        if (frame == 23) { _frame_23(); }
        if (frame == 24) { _frame_24(); }
        if (frame == 25) { _frame_25(); }
        if (frame == 26) { _frame_26(); }
        if (frame == 27) { _frame_27(); }
        if (frame == 28) { _frame_28(); }
        if (frame == 29) { _frame_29(); }
        if (frame == 30) { _frame_30(); }
        if (frame == 31) { _frame_31(); }
        if (frame == 32) { _frame_32(); }
        if (frame == 33) { _frame_33(); }
        if (frame == 34) { _frame_34(); }
        if (frame == 35) { _frame_35(); }
        if (frame == 36) { _frame_36(); }
        if (frame == 37) { _frame_37(); }
        if (frame == 38) { _frame_38(); }
        if (frame == 39) { _frame_39(); }
        if (frame == 40) { _frame_40(); }
        if (frame == 41) { _frame_41(); }
        if (frame == 42) { _frame_42(); }
        if (frame == 43) { _frame_43(); }
        if (frame == 44) { _frame_44(); }
        if (frame == 45) { _frame_45(); }
        if (frame == 46) { _frame_46(); }
        if (frame == 47) { _frame_47(); }
        if (frame == 48) { _frame_48(); }
        if (frame == 49) { _frame_49(); }
        if (frame == 50) { _frame_50(); }
        if (frame == 51) { _frame_51(); }
        if (frame == 52) { _frame_52(); }
        if (frame == 53) { _frame_53(); }
        if (frame == 54) { _frame_54(); }
        if (frame == 55) { _frame_55(); }
        if (frame == 56) { _frame_56(); }
        if (frame == 57) { _frame_57(); }
        if (frame == 58) { _frame_58(); }
        if (frame == 59) { _frame_59(); }
    }
}

fn start() {
    running = true;
    frame = 0;
    title(@a, "§6§lRedScript", "§7software rasterizer · 21×17 · 60 frames");
    say("§a▶ cube demo  — face any wall, stand back ~15 blocks");
    say("§7/function cubedemo:stop  to clear");
}

fn stop() {
    running = false;
    // Clear the screen
    foreach (p in @a) at @s {
        fill((^-10, ^-8, ^6), (^10, ^8, ^6), "air");
    }
    say("§c■ cube demo stopped");
}

