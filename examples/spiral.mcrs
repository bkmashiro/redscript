// ===== Simple Particle Demo =====
// 展示: @tick, 状态管理, f-strings, 控制命令

// 状态
let counter: int = 0;
let running: bool = false;

// ===== 主循环 =====
@tick fn demo_tick() {
    if (!running) { return; }
    
    // 每 tick 增加计数器
    counter = counter + 1;
    
    // 在玩家位置生成粒子
    particle("minecraft:end_rod", ~0, ~1, ~0, 0.5, 0.5, 0.5, 0.1, 5);
    
    // 每 20 ticks (1秒) 报告一次
    if (counter % 20 == 0) {
        say(f"Running for {counter} ticks");
    }
}

// ===== 控制命令 =====
fn start() {
    running = true;
    counter = 0;
    say(f"Demo started!");
}

fn stop() {
    running = false;
    say(f"Demo stopped at {counter} ticks.");
}

fn reset() {
    running = false;
    counter = 0;
    say(f"Demo reset.");
}
