fn start() {
    on = true;
    frame = 0;
    title(@a, "§e y = x·sin(x)", "§7curve demo  ·  face forward  ·  3 curves");
    say("§a▶ curve demo — face any direction");
    say("§7stop: /function rsdemo:stop");
}

fn stop() {
    on = false;
    actionbar(@a, "§7[ demo stopped ]");
    say("§c■ demo stopped");
}
