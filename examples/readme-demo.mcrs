fn start() {
    on     = true;
    phase  = 0;
    draw_x = 0;
    title(@a, "§e y = sin(x + t)", "§7sin_fixed · 40 pts · particles");
    say("§a▶ sine wave — face forward, stand back 8 blocks");
}

fn stop() {
    on = false;
    say("§c■ stopped");
}
