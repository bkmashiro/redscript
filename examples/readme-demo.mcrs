// readme-demo.mcrs — RedScript v1.2.29 README visual showcase
// 5 mathematical curves traced with particles:
//   1. y = x·sin(x)            2. y = sin(x)+½sin(2x)
//   3. y = e^(-|x|)·sin(4x)   4. y = tanh(2x)   5. r = cos(2θ) rose
//
// Compile:  node dist/cli.js compile examples/readme-demo.mcrs -o <out> --namespace rsdemo
// In-game:  /function rsdemo:start   (face any direction)
//           /function rsdemo:stop

import "../src/stdlib/math.mcrs"

let frame: int = 0;
let on:    bool = false;

@load fn _init() { frame = 0; }

@tick fn _wave_tick() {
    if (!on) { return; }
    frame = frame + 1;

    // 5 curves × 128 ticks each
    let curve_id: int = (frame / 128) % 5;

    if (curve_id == 0) { actionbar(@a, "§e  y = x·sin(x)"); }
    if (curve_id == 1) { actionbar(@a, "§c  y = sin(x) + ½sin(2x)"); }
    if (curve_id == 2) { actionbar(@a, "§b  y = e^{-|x|}·sin(4x)  (damped)"); }
    if (curve_id == 3) { actionbar(@a, "§a  y = tanh(2x)  (sigmoid / S-curve)"); }
    if (curve_id == 4) { actionbar(@a, "§d  r = cos(2θ)  (rose curve)"); }

    foreach (p in @a) at @s {
        if (curve_id == 0) { _draw_xsinx(); }
        if (curve_id == 1) { _draw_harmonic(); }
        if (curve_id == 2) { _draw_damped(); }
        if (curve_id == 3) { _draw_tanh(); }
        if (curve_id == 4) { _draw_rose(); }
    }
}

