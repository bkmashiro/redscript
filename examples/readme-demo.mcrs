fn start() {
    on = true;
    frame = 0;
    title(@a, "§e RedScript", "§7math curve demo  ·  5 curves");
    say("§a▶ curve demo — face forward, stand back ~12 blocks");
    say("§7stop: /function rsdemo:stop");
}

fn stop() {
    on = false;
    actionbar(@a, "§7[ demo stopped ]");
    say("§c■ demo stopped");
}
