// readme-demo.mcrs — RedScript animated 2D sine wave
// Real-time computation using sin_fixed() from the math stdlib.
//
// Strategy: 40 x-points cycled one per tick, each refreshed with count=5
// end_rod particles (lifetime ~40 ticks) → full curve always visible.
// phase advances 1°/tick → smooth scrolling animation.
//
// Compile:
//   node dist/cli.js compile examples/readme-demo.mcrs \
//       -o <out> --namespace rsdemo
// In-game:
//   /function rsdemo:start   (face forward, stand 8+ blocks back)
//   /function rsdemo:stop

import "../src/stdlib/math.mcrs"

let phase:  int  = 0;
let draw_x: int  = 0;
let on:     bool = false;

@load fn _init() {
    phase  = 0;
    draw_x = 0;
}

@tick fn _wave_tick() {
    if (!on) { return; }

    // Advance draw cursor and phase
    draw_x = (draw_x + 1) % 40;
    phase  = (phase  + 1) % 360;

    // sin at current x-point with scrolling phase
    // x * 9° = one full period over 40 steps; + phase for scroll
    let deg:    int = (draw_x * 9 + phase) % 360;
    let s:      int = sin_fixed(deg);

    // Bucket sin(-1000..1000) → 0..10
    let bucket: int = (s + 1050) / 200;

    foreach (p in @a) at @s {
        if (draw_x == 0) {
            if (bucket == 0) { particle("minecraft:end_rod", ^-9.75, ^-2.5, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 1) { particle("minecraft:end_rod", ^-9.75, ^-2.0, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 2) { particle("minecraft:end_rod", ^-9.75, ^-1.5, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 3) { particle("minecraft:end_rod", ^-9.75, ^-1.0, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 4) { particle("minecraft:end_rod", ^-9.75, ^-0.5, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 5) { particle("minecraft:end_rod", ^-9.75, ^0.0, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 6) { particle("minecraft:end_rod", ^-9.75, ^0.5, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 7) { particle("minecraft:end_rod", ^-9.75, ^1.0, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 8) { particle("minecraft:end_rod", ^-9.75, ^1.5, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 9) { particle("minecraft:end_rod", ^-9.75, ^2.0, ^5, 0.04,0.04,0.04, 0.0, 5); }
            if (bucket == 10) { particle("minecraft:end_rod", ^-9.75, ^2.5, ^5, 0.04,0.04,0.04, 0.0, 5); }
        }
        if (draw_x == 1) {
            if (bucket == 0) { particle("minecraft:end_rod", ^-9.25, ^-2.5, ^5, 0.04,0.04,0.04, 0.0, 5); }
