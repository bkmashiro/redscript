// readme-demo.mcrs — RedScript v1.2.29 README visual showcase
// Draws three mathematical curves using particles traced along fixed curve points.
// Curves:  y=x·sin(x)  |  Lissajous 3:2  |  y=sin(x)+½sin(2x)
//
// Compile:  node dist/cli.js compile examples/readme-demo.mcrs -o <out> --namespace rsdemo
// In-game:  /function rsdemo:start   (face any direction)
//           /function rsdemo:stop

import "../src/stdlib/math.mcrs"

let frame: int = 0;
let on:    bool = false;

@load fn _init() { frame = 0; }

@tick fn _wave_tick() {
    if (!on) { return; }
    frame = frame + 1;

    let curve_id: int = (frame / 300) % 3;   // switch curve every 15 s
    let idx:      int = frame % 32;           // tracer position (0..31)

    // Actionbar
    if (curve_id == 0) { actionbar(@a, f"§e  y = x·sin(x)   §7idx={idx}"); }
    if (curve_id == 1) { actionbar(@a, f"§b  Lissajous  x=sin(3t), y=cos(2t)   §7t={idx}/32"); }
    if (curve_id == 2) { actionbar(@a, f"§c  y = sin(x) + ½sin(2x)   §7idx={idx}"); }

    foreach (p in @a) at @s {
        if (curve_id == 0) { _draw_xsinx(idx); }
        if (curve_id == 1) { _draw_lissajous(idx); }
        if (curve_id == 2) { _draw_harmonic(idx); }
    }
}

